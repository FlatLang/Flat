{
  "name": "Flat-Website-Backend",
  "version": "0.1.0",
  "description": "Flat Website Backend",
  "author": "Braden Steffaniak",
  "license": "ISC",
  "defaultTarget": "es6",
  "sources": {
    "main": {
      "mainClass": "flat/website/functions/StatusBadge",
      "source": "src",
      "dependencies": {
        "https://github.com/FlatLang/System.git": "master",
        "https://github.com/FlatLang/IO.git": "master",
        "https://github.com/FlatLang/Json.git": "master",
        "https://github.com/FlatLang/Http.git": "master",
        "https://github.com/FlatLang/Time.git": "master",
        "https://github.com/FlatLang/FuCli.git": "master",
        "https://github.com/FlatLang/Logger.git": "master",
        "https://github.com/FlatLang/Cache.git": "master",
        "https://github.com/FlatLang/GitHubClient.git": "master"
      }
    },
    "cmd": {
      "mainClass": "flat/website/functions/Functions_Command",
      "source": "src",
      "dependencies": {}
    },
    "server": {
      "mainClass": "flat/website/functions/Functions_Server",
      "source": "src",
      "outFile": "server.js",
      "dependencies": {}
    },
    "test": {
      "mainClass": "flat/website/functions/StatusBadge_TestSuite",
      "source": "src/**/*_Test*.flat",
      "dependencies": {
        "https://github.com/FlatLang/Test.git": "master"
      }
    }
  }
}
