package flat/git

testable class {
    test `can create`() {
        let value = Git()

        expect(value).toNotBe(null)
    }

    async test `can fetch remote info`() {
        let repo = "https://github.com/FlatLang/Flat"
        let info = Git.remoteInfo(repo, silent: true)

        expect(info.remote).toBe(repo)
        expect(info.fetchUrl).toBe(repo)
        expect(info.pushUrl).toBe(repo)
        expect(info.headBranch).toBe("master")
        expect(info.success).toBe(true)
    }

    async test `can fetch remote tags`() {
        let info = Git.lsRemoteTags("https://github.com/FlatLang/Flat", silent: true)

        expect(info.success).toBe(true)
        expect(info.tags.any({ _.name.startsWith("flat-") })).toBe(true)
        expect(info.tags.first.name.count > 0).toBe(true)
    }
}
